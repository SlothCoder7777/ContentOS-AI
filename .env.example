# ============================================
# ContentOS AI - Environment Variables Example
# ============================================

# App
APP_NAME=ContentOS AI
ENVIRONMENT=development
DEBUG=True

# Database
# Use your actual Neon PostgreSQL connection string in .env
# Example format:
# postgresql+psycopg://USER:PASSWORD@HOST/DB_NAME?sslmode=require
DATABASE_URL=postgresql+psycopg://YOUR_USER:YOUR_PASSWORD@YOUR_NEON_HOST/YOUR_DATABASE?sslmode=require

# JWT / Auth
SECRET_KEY=replace-this-with-a-long-random-secret-key
JWT_SECRET_KEY=replace-this-with-a-long-random-secret-key
ALGORITHM=HS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
# OpenAI
OPENAI_API_KEY=replace-this-with-your-openai-api-key
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=1000
OPENAI_MAX_RETRIES=1000
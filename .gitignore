# ============================================
# ContentOS AI - Python / FastAPI .gitignore
# ============================================

# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*
!.env.example

# Python build files
build/
dist/
*.egg-info/
.eggs/
*.egg

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# MyPy / Ruff / type checking cache
.mypy_cache/
.ruff_cache/
.pyre/

# Alembic temporary files
alembic/versions/__pycache__/

# Logs
*.log
logs/

# SQLite local testing databases
*.sqlite3
*.db

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# Windows files
Thumbs.db
Desktop.ini

# macOS files
.DS_Store

# IDE files
.idea/

# Temporary files
*.tmp
*.temp